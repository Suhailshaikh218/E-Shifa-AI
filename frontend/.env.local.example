# ============================================
# E-SHIFA AI - FRONTEND ENVIRONMENT VARIABLES
# ============================================

# ============================================
# API CONFIGURATION
# ============================================

# For Local Development:
NEXT_PUBLIC_API_URL=http://localhost:8000

# For Production (after deploying backend to Google Cloud Run):
# NEXT_PUBLIC_API_URL=https://your-backend-xxxxx-as.a.run.app

# ============================================
# NOTES
# ============================================

# 1. All frontend env vars MUST start with NEXT_PUBLIC_
# 2. Update API URL after deploying backend
# 3. Never commit .env.local with production values
# 4. Use HTTPS in production
